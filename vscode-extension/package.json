{
  "name": "superpowers-mcp",
  "displayName": "Superpowers MCP",
  "description": "Superpowers skills library (TDD, debugging, collaboration workflows) as an MCP server for VSCode, Trae, and Antigravity",
  "version": "4.3.0",
  "publisher": "superpowers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/obra/superpowers"
  },
  "homepage": "https://github.com/obra/superpowers",
  "keywords": [
    "mcp",
    "ai",
    "skills",
    "tdd",
    "debugging",
    "collaboration",
    "best-practices",
    "workflows",
    "copilot",
    "agent"
  ],
  "bin": {
    "superpowers-mcp": "./out/server.js"
  },
  "files": [
    "out",
    "skills"
  ],
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "prepublishOnly": "npm run copy-skills && npm run build",
    "copy-skills": "node scripts/copy-skills.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}